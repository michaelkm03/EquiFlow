{
  "name": "equiflow-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests for EquiFlow trading engine",
  "scripts": {
    "test": "playwright test --project=regression",
    "test:ui": "playwright test --project=ui",
    "test:smoke": "playwright test --project=smoke",
    "test:integration": "playwright test --project=integration",
    "test:e2e": "playwright test --project=e2e",
    "test:headed": "playwright test --headed",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:orders": "playwright test tests/orders.spec.ts",
    "test:compliance": "playwright test tests/compliance.spec.ts",
    "test:market": "playwright test tests/market-data.spec.ts",
    "test:ledger": "playwright test tests/ledger.spec.ts",
    "test:audit": "playwright test tests/audit.spec.ts",
    "test:order-flow": "playwright test tests/order-flow.spec.ts",
    "report": "playwright show-report",
    "report:open": "playwright show-report --host 0.0.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "typescript": "^5.4.0"
  }
}
